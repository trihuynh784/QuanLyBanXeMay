{
  "openapi": "3.0.0",
  "info": {
    "title": "QuanLyBanXe-LongL API",
    "description": "API Documentation",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Development Server"
    }
  ],
  "tags": [
    {
      "name": "Khách hàng",
      "description": "User management APIs"
    },
    {
      "name": "Nhân viên",
      "description": "Staff management APIs"
    },
    {
      "name": "Đơn hàng",
      "description": "Order management APIs"
    },
    {
      "name": "Xe",
      "description": "Vehicle management APIs"
    },
    {
      "name": "Auth",
      "description": "Authentication APIs"
    }
  ],
  "paths": {
    "/vehicles": {
      "get": {
        "tags": ["Xe"],
        "summary": "Lấy danh sách xe",
        "responses": {
          "200": {
            "description": "Get all vehicles successfully",
            "content": {
              "application/json": {
                "example": {
                  "message": "Get all vehicles successfully",
                  "data": [
                    {
                      "_id": "64a1b2c3d4e5f67890abcdef",
                      "tenXe": "Toyota Camry",
                      "gia": 25000,
                      "soLuong": 10
                    },
                    {
                      "_id": "64a1b2c3d4e5f67890abcdee",
                      "tenXe": "Honda Accord",
                      "gia": 22000,
                      "soLuong": 15
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/vehicles/detail/{id}": {
      "get": {
        "tags": ["Xe"],
        "summary": "Lấy chi tiết xe theo ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": {}
          },
          "404": {
            "description": "Vehicle not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/customers/{id}": {
      "get": {
        "tags": ["Khách hàng"],
        "summary": "Lấy chi tiết khách hàng theo ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": {}
          },
          "404": {
            "description": "Customer not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/staffs/{id}": {
      "get": {
        "tags": ["Nhân viên"],
        "summary": "Lấy chi tiết nhân viên theo ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "default": "64a1b2c3d4e5f67890abcdef"
            }
          }
        ],
        "responses": {
          "200": {
            "description": {}
          },
          "404": {
            "description": "Staff not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/sign-in": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng nhập người dùng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "buoithanhminh"
                  },
                  "password": {
                    "type": "string",
                    "example": "minhbuoi123"
                  }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": {}
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/sign-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng ký người dùng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "buoithanhminh"
                  },
                  "password": {
                    "type": "string",
                    "example": "minhbuoi123"
                  },
                  "fullName": {
                    "type": "string",
                    "example": "Nguyễn Thanh Minh"
                  },
                  "cccd": {
                    "type": "string",
                    "example": "012345678912"
                  },
                  "phoneNumber": {
                    "type": "string",
                    "example": "0987654321"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "thanhminh@gmail.com"
                  },
                  "address": {
                    "type": "string",
                    "example": "Số 123 Đường Ba Đình, Hà Nội"
                  }
                },
                "required": [
                  "username",
                  "password",
                  "fullName",
                  "cccd",
                  "phoneNumber",
                  "email",
                  "address"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": {}
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
