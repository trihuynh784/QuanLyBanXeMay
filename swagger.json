    "/auth/sign-in": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng nhập người dùng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "kh001"
                  },
                  "password": {
                    "type": "string",
                    "example": "123456"
                  }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dang nhap thanh cong!",
            "content": {
              "application/json": {
                "example": {
                  "message": "Sign-in successful",
                  "user": {
                    "id": "6a1bf84cdbf514b834332839",
                    "fullName": "Lê Văn A",
                    "email": "a@gmail.com",
                    "phoneNumber": "0911111111",
                    "address": "HCM",
                    "cccd": "012345678901",
                    "status": true
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/auth/sign-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng ký người dùng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "buoithanhminh"
                  },
                  "password": {
                    "type": "string",
                    "example": "minhbuoi123"
                  },
                  "fullName": {
                    "type": "string",
                    "example": "Nguyễn Thanh Minh"
                  },
                  "cccd": {
                    "type": "string",
                    "example": "012345678912"
                  },
                  "phoneNumber": {
                    "type": "string",
                    "example": "0987654321"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "thanhminh@gmail.com"
                  },
                  "address": {
                    "type": "string",
                    "example": "Số 123 Đường Ba Đình, Hà Nội"
                  }
                },
                "required": [
                  "username",
                  "password",
                  "fullName",
                  "cccd",
                  "phoneNumber",
                  "email",
                  "address"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": {}
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
